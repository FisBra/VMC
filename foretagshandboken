                  <div class="vmc-contact-label">Skyddsombud / Arbetsmiljö</div>
                  <div class="vmc-contact-value">Simon Johansson, Per Björklund, Johan Gardelius</div>
                </div>
                <div class="vmc-contact-item">
                  <div class="vmc-contact-label">IF Metall</div>
