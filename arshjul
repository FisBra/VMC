  svg {
    max-width: 400px;
    display: block;
  }

  .month-slice path {
    cursor: pointer;
    transition: fill 0.3s, filter 0.3s, stroke 0.3s;
  }

  .month-slice path.active-month {
    stroke: #333;
    stroke-width: 2;
    filter: brightness(1.2);
  }

  table {
    border-collapse: collapse;
    width: 100%;
    margin-top: 0.5rem;
  }

  th,
  td {
    border: 1px solid #ccc;
