    text-align: left;
  }

  th {
    background: #f0f0f0;
  }

  .month-table { display: none; }
  .month-table.active { display: table; }

  #month-title {
    font-size: 1.3rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
    transition: color 0.3s ease;
  }

  /* Årshjulet – håll allt i tabellen på en rad */
  .month-table td,
  .month-table th {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis; /* klipper texten om den blir för lång */
  }

